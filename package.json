{
  "name": "nestjs-protobuf-es",
  "version": "0.1.1",
  "description": "Protobuf-ES integration for NestJS",
  "keywords": [
    "nestjs",
    "protobuf",
    "protobuf-es",
    "buf",
    "bufbuild",
    "grpc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/m4w1s/nestjs-protobuf-es.git"
  },
  "author": "Mawis",
  "bin": {
    "protoc-gen-nestjs": "bin/protoc-gen-nestjs"
  },
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "/bin",
    "/dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "format": "biome check --write --linter-enabled=false",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome check --write",
    "test": "rimraf dist && tsc -p tsconfig.json && node --test test/*.test.cjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protoplugin": "^2.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@grpc/grpc-js": "^1.14.3",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.5.2",
    "@grpc/grpc-js": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@bufbuild/protobuf": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.14.1"
}
